{
  "info": {
    "name": "DRIP API",
    "description": "Base URL: http://localhost:4000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "cartProductId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1&limit=12",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "12"
                }
              ]
            },
            "description": "List all products with pagination. Supports filtering via query params."
          },
          "response": []
        },
        {
          "name": "List Products — Filtered",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?gender=male&colours=black&minPrice=500&maxPrice=1000",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ],
              "query": [
                {
                  "key": "gender",
                  "value": "male"
                },
                {
                  "key": "colours",
                  "value": "black"
                },
                {
                  "key": "minPrice",
                  "value": "500"
                },
                {
                  "key": "maxPrice",
                  "value": "1000"
                }
              ]
            },
            "description": "List products with filters: gender, colours, types, minPrice, maxPrice, search."
          },
          "response": []
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?search=polo&limit=5",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "polo"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "description": "Search products by name. Uses MongoDB text index."
          },
          "response": []
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "{{productId}}"
              ]
            },
            "description": "Get a single product by ID. Set the `productId` variable after listing products."
          },
          "response": []
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Test Tee",
                  "type": "text"
                },
                {
                  "key": "type",
                  "value": "crew neck",
                  "type": "text"
                },
                {
                  "key": "gender",
                  "value": "unisex",
                  "type": "text"
                },
                {
                  "key": "colour",
                  "value": "white",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "499",
                  "type": "text"
                },
                {
                  "key": "quantity",
                  "value": "10",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Create a new product. Requires multipart form-data with an image file."
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "{{productId}}"
              ]
            },
            "description": "Delete a product by ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cart"
              ]
            },
            "description": "Get the current cart. Uses a static user ID (no auth required)."
          },
          "response": []
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cart"
              ]
            },
            "description": "Add a product to the cart. Set `productId` variable first. Quantity cannot exceed stock."
          },
          "response": []
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cart/{{cartProductId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "{{cartProductId}}"
              ]
            },
            "description": "Update the quantity of a cart item. Set `cartProductId` to the product ID in the cart."
          },
          "response": []
        },
        {
          "name": "Remove from Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cart/{{cartProductId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "{{cartProductId}}"
              ]
            },
            "description": "Remove an item from the cart by product ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Static Files",
      "item": [
        {
          "name": "Get Product Image",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/uploads/classic-white-tee.jpg",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "uploads",
                "classic-white-tee.jpg"
              ]
            },
            "description": "Serve product images from the uploads directory."
          },
          "response": []
        }
      ]
    }
  ]
}
